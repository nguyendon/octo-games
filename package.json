{
  "name": "octo-games",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @octo/server --filter @octo/client run dev",
    "build": "pnpm --filter @octo/client run build && pnpm --filter @octo/server run build",
    "start": "pnpm --filter @octo/server run start"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
