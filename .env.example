# Local dev defaults are shown — override on Railway as needed.

# Server bind. Railway sets PORT automatically; HOST stays 0.0.0.0.
PORT=3000
HOST=0.0.0.0

# Where the SQLite file lives. Defaults to server/data when unset.
# On Railway, mount a volume (e.g. at /data) and set:
#   DATA_DIR=/data
DATA_DIR=
